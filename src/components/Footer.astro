---
// Patička webu TOP-assist24 s fakturačními údaji a odkazy
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-950 border-t border-slate-900 pt-16 pb-8 mt-auto w-full">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-12">
      <!-- Sloupec 1: O firmě a rychlé SOS volání -->
      <div class="space-y-4">
        <div class="flex items-center space-x-2">
          <div class="h-8 w-8 bg-amber-500 rounded-md flex items-center justify-center font-extrabold text-slate-950 tracking-tighter">
            TA
          </div>
          <span class="font-extrabold text-lg tracking-tight text-white">TOP-assist24</span>
        </div>
        <p class="text-xs sm:text-sm text-slate-400 leading-relaxed">
          Spolehlivý partner pro odtahy, silniční asistenci a vyprošťování. Působíme nonstop v Třebíči, Jihlavě, Velkém Meziříčí a po celé České republice.
        </p>
        <div class="pt-2">
          <a 
            href="tel:+420603167167" 
            class="inline-flex items-center space-x-2 bg-emerald-500 hover:bg-emerald-400 text-slate-950 px-4 py-2.5 rounded-lg font-bold text-xs tracking-wider transition-colors border border-emerald-400"
          >
            <span>DISPEČINK: +420 603 167 167</span>
          </a>
        </div>
      </div>

      <!-- Sloupec 2: Naše asistenční služby -->
      <div>
        <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">Služby</h3>
        <ul class="space-y-2.5 text-sm text-slate-300">
          <li>
            <a href="/sluzby/odtah-osobnich" class="hover:text-amber-500 transition-colors">Osobní a nákladní asistence</a>
          </li>
          <li>
            <a href="/sluzby/vyprosteni-nakladni" class="hover:text-amber-500 transition-colors">Odtah a vyproštění vozidel</a>
          </li>
          <li>
            <a href="/sluzby/autozamecnik" class="hover:text-amber-500 transition-colors">Nouzové otevírání (autozámečník)</a>
          </li>
          <li>
            <a href="/sluzby/cykloasistence" class="hover:text-amber-500 transition-colors">Cykloasistence pro cyklisty</a>
          </li>
        </ul>
      </div>

      <!-- Sloupec 3: Oblasti kde nejčastěji působíme -->
      <div>
        <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">Kde působíme</h3>
        <ul class="space-y-2.5 text-sm text-slate-300">
          <li>
            <a href="/" class="hover:text-amber-500 transition-colors">Odtahovka Třebíč</a>
          </li>
          <li>
            <a href="/oblast-pusobeni/jihlava" class="hover:text-amber-500 transition-colors">Odtahovka Jihlava</a>
          </li>
          <li>
            <a href="/oblast-pusobeni/velke-mezirici" class="hover:text-amber-500 transition-colors">Odtahovka Velké Meziříčí</a>
          </li>
          <li>
            <a href="/oblast-pusobeni/moravske-budejovice" class="hover:text-amber-500 transition-colors">Odtahovka Moravské Budějovice</a>
          </li>
        </ul>
      </div>

      <!-- Sloupec 4: Kontaktní a fakturační údaje -->
      <div>
        <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">Kontakty a Sídlo</h3>
        <p class="text-sm text-slate-300 leading-relaxed mb-4">
          <strong>TOP-assist24 s.r.o.</strong><br />
          Sídlo: Polanka 214/10, Třebíč 674 01<br />
          Základna/Provozovna: Hrotovická 1202, Třebíč 674 01<br />
          IČO: 06214532 | DIČ: CZ06214532<br />
          Email: <a href="mailto:info@topassist.cz" class="hover:text-amber-500 transition-colors">info@topassist.cz</a>
        </p>
      </div>
    </div>

    <!-- Spodní lišta s autorskými právy a doplňujícími informacemi -->
    <div class="border-t border-slate-900 pt-8 flex flex-col md:flex-row items-center justify-between text-xs text-slate-500">
      <p>© {currentYear} TOP-assist24 s.r.o. Všechna práva vyhrazena.</p>
    </div>
  </div>
</footer>
