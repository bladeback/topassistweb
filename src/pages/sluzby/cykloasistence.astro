---
// Podstránka pro cykloasistenční služby (pomoc cyklistům na cestách)
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';

// Importujeme náš vygenerovaný obrázek odtahovky jako pozadí
import heroOdtahovka from '../../assets/images/placeholder-odtahovka.png';
---

<Layout 
  title="Cykloasistence Nonstop Třebíč & Vysočina | TOP-assist24" 
  description="Měli jste poruchu na kole nebo elektrokole na Vysočině? Nabízíme nonstop cykloasistenci. Odvezeme vaše poškozené kolo i s vámi bezpečně domů."
>
  <Header />

  <main class="flex-grow">
    
    <!-- Hero / Nadpis sekce -->
    <section class="relative bg-slate-950 py-16 overflow-hidden border-b border-slate-900">
      <div class="absolute inset-0 z-0 opacity-15">
        <Image 
          src={heroOdtahovka} 
          alt="Žlutý odtahový vůz zachycený z boku" 
          class="w-full h-full object-cover filter grayscale"
        />
        <div class="absolute inset-0 bg-slate-950/90"></div>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          
          <!-- Answer Capsule pro SEO/GEO AI Boty -->
          <div class="inline-block bg-amber-500/10 border border-amber-500/20 px-3 py-1 rounded-full text-xs font-bold text-amber-500 mb-4">
            Nonstop asistenční služba a odtah kol pro cyklisty na Vysočině
          </div>

          <h1 class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight leading-none">
            Cykloasistence pro cyklisty
          </h1>
          <p class="mt-4 text-slate-300 text-base leading-relaxed">
            Porucha kola, vybitá baterie u elektrokola nebo únava na cyklostezce? Přijedeme pro vás a vaše kolo kamkoliv na Vysočině.
          </p>
        </div>
      </div>
    </section>

    <!-- Detailní popis služby -->
    <section class="py-16 w-full bg-slate-950">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
          
          <!-- Hlavní text (sloupce 1 & 2) -->
          <div class="lg:col-span-2 space-y-8 text-slate-300">
            
            <div>
              <h2 class="text-2xl font-bold text-white mb-4">Rychlá pomoc na cyklostezkách Vysočiny</h2>
              <p class="leading-relaxed mb-4">
                Vysočina je rájem cyklistů, ale i na těch nejkrásnějších trasách může dojít k nepříjemné události. Defekt, který nelze opravit na místě, přetržený řetěz, pád a lehké zranění, nebo prosté vybití akumulátoru vašeho elektrokola vás mohou nechat bezmocné kilometry od domova nebo ubytování.
              </p>
              <p class="leading-relaxed">
                Asistenční služba TOP-assist24 nabízí unikátní cykloasistenci. Disponujeme speciálními držáky a přepravními boxy pro bezpečnou a šetrnou přepravu jízdních kol, silničních speciálů i těžkých elektrokol. Přijedeme k vám na lesní cestu, k silnici nebo přímo na cyklostezku a odvezeme vás i vaše kolo do servisu nebo na hotel.
              </p>
            </div>

            <!-- Výhody služby -->
            <div class="bg-slate-900/40 p-6 rounded-xl border border-slate-900">
              <h3 class="text-lg font-bold text-white mb-4">Co cykloasistence zahrnuje?</h3>
              <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm text-slate-400">
                <li class="flex items-center space-x-2">
                  <span class="text-amber-500">✓</span>
                  <span>Přeprava až 4 kol a osob najednou</span>
                </li>
                <li class="flex items-center space-x-2">
                  <span class="text-amber-500">✓</span>
                  <span>Bezpečné uchycení a fixace kol při převozu</span>
                </li>
                <li class="flex items-center space-x-2">
                  <span class="text-amber-500">✓</span>
                  <span>Odtah těžkých elektrokol při vybití</span>
                </li>
                <li class="flex items-center space-x-2">
                  <span class="text-amber-500">✓</span>
                  <span>Dovoz k nejbližšímu cykloservisu</span>
                </li>
                <li class="flex items-center space-x-2">
                  <span class="text-amber-500">✓</span>
                  <span>Doprovod a odvoz rodin s dětmi</span>
                </li>
                <li class="flex items-center space-x-2">
                  <span class="text-amber-500">✓</span>
                  <span>Nonstop provoz i o víkendech a svátcích</span>
                </li>
              </ul>
            </div>

            <div>
              <h2 class="text-xl font-bold text-white mb-3">Jak probíhá zásah cykloasistence?</h2>
              <p class="leading-relaxed">
                Při poruše na cyklostezce doporučujeme využít naši funkci <strong>"Sdílet polohu"</strong> na hlavní stránce tohoto webu. Geolocation API zjistí vaše přesné GPS souřadnice, které nám odešlete přes SMS. Dispečink okamžitě lokalizuje vaši polohu a pošle k vám asistenční vozidlo vybavené pro transport cyklistů.
              </p>
            </div>

          </div>

          <!-- Pravý boční panel - SOS Call to Action -->
          <div class="space-y-6">
            <div class="bg-gradient-to-br from-slate-900 to-slate-950 p-8 rounded-xl border-2 border-emerald-500/20 text-center">
              <span class="text-4xl mb-4 block">🚲</span>
              <h3 class="text-xl font-bold text-white mb-2">Uvízli jste s kolem?</h3>
              <p class="text-sm text-slate-400 mb-6 leading-relaxed">
                Nonstop cykloodtah po celé Vysočině. Zavolejte nám, nahlaste polohu a během chvíle jsme u vás.
              </p>
              <a 
                href="tel:+420603167167" 
                class="block w-full bg-emerald-500 hover:bg-emerald-400 text-slate-950 font-black py-4 rounded-lg tracking-wider text-base transition-colors border border-emerald-400"
              >
                VOLAT CYKLOASISTENCI
              </a>
            </div>

            <div class="bg-slate-900/40 p-6 rounded-xl border border-slate-900">
              <h4 class="font-bold text-white mb-3">Pojištění kol</h4>
              <p class="text-xs text-slate-400 leading-relaxed">
                Všechna přepravovaná jízdní kola a elektrokola jsou po dobu transportu plně pojištěna proti poškození. Používáme výhradně atestované držáky a systémy Thule.
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
